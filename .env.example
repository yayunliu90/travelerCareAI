# Copy to .env — do not commit .env.

# Logging: DEBUG | INFO | WARNING | ERROR (default INFO).
# LOG_LEVEL=
# Log file (rotating). Default: logs/travelcare.log under project root. Set LOG_DISABLE_FILE=1 for console only.
# LOG_FILE=
# LOG_DISABLE_FILE=
# LOG_FILE_MAX_MB=10
# LOG_FILE_BACKUP_COUNT=5

# Optional: enables LLM-assisted structuring + explanations.
OPENAI_API_KEY=

# Optional: default trip context when the client does not send "location" (e.g. City, Country).
DEFAULT_TRAVEL_LOCATION=

# Optional: default home country/region when the client does not send "home_country" (for healthcare comparison).
DEFAULT_HOME_COUNTRY=

# Browser key: enable Maps JavaScript API + Places API; restrict by HTTP referrer in Google Cloud.
GOOGLE_MAPS_API_KEY=

# Server key (IP-restricted or unrestricted for server use): Geocoding + Places Nearby + Place Details for LLM tools.
# Enable Geocoding API, Places API, on the same key as appropriate. Browser-restricted keys often fail server-side.
GOOGLE_MAPS_SERVER_KEY=

# Serper.dev key for web search (https://serper.dev). Do not put a SerpAPI.com key here — use SERPAPI_API_KEY below.
SERPER_API_KEY=

# SerpAPI.com key (https://serpapi.com). If Serper returns 403/401, the server may retry the same value as SerpAPI when this is unset (misnamed key in SERPER_API_KEY).
SERPAPI_API_KEY=

# Set to 1 to disable the research tool loop (Places + web) globally.
# DISABLE_RESEARCH_TOOLS=
